{
  "name": "luma-vue",
  "version": "0.0.1-beta.4",
  "packageManager": "pnpm@8.6.10",
  "description": "Build Accessible Apps 10x faster",
  "author": "Ivatra",
  "license": "MIT",
  "funding": "https://github.com/sponsors/ivatra",
  "homepage": "https://github.com/ivatra/luma-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivatra/luma-ui.git"
  },
  "bugs": "https://github.com/ivatra/luma-ui/issues",
  "keywords": [
    "vue ui",
    "luma ui",
    "component library",
    "ui",
    "vue 3",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/luma-ui.cjs",
      "import": "./dist/luma-ui.mjs"
    },
    "./dist/theme/lumaTheme": {
      "require": "./dist/theme/lumaTheme.ts",
      "import": "./dist/theme/lumaTheme.ts"
    }
  },
  "main": "./dist/luma-ui.cjs",
  "module": "./dist/luma-ui.mjs",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build && pnpm run build:theme",
    "build:watch": "vite build --watch",
    "build:theme": "esno ./scripts/theme.ts",
    "dev": "vite",
    "play": "pnpm --filter playground dev",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm build && bumpp --commit --push --tag && pnpm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "peerDependencies": {
    "vue": "^3.3.4"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.15",
    "@heroicons/vue": "^2.0.18",
    "classnames": "^2.3.2",
    "esno": "^0.17.0",
    "tailwind-merge": "^1.14.0",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.39.8",
    "@vitejs/plugin-vue": "^4.2.3",
    "bumpp": "^9.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6",
    "vite": "^4.4.7",
    "vite-plugin-dts": "^3.3.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
